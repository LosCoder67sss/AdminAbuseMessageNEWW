-- LocalScript - Sistema de texto flotante apilado con fade out

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TextOverlayGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- Frame contenedor: arriba al centro (donde aparece el texto)
local textFrame = Instance.new("Frame")
textFrame.Size = UDim2.new(0.5, 0, 0.3, 0)
textFrame.Position = UDim2.new(0.25, 0, 0.05, 0) -- arriba al centro
textFrame.BackgroundTransparency = 1
textFrame.ClipsDescendants = false
textFrame.Parent = screenGui

local listLayout = Instance.new("UIListLayout")
listLayout.Parent = textFrame
listLayout.SortOrder = Enum.SortOrder.LayoutOrder
listLayout.VerticalAlignment = Enum.VerticalAlignment.Top
listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
listLayout.Padding = UDim.new(0, 2)

-- TextBox abajo al centro
local textBox = Instance.new("TextBox")
textBox.Size = UDim2.new(0.25, 0, 0.05, 0)
textBox.Position = UDim2.new(0.375, 0, 0.85, 0) -- abajo centro
textBox.PlaceholderText = "Escribe aqui..."
textBox.ClearTextOnFocus = false
textBox.Text = ""
textBox.Font = Enum.Font.SourceSansBold
textBox.TextSize = 18
textBox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.BorderSizePixel = 0
textBox.Parent = screenGui

Instance.new("UICorner", textBox).CornerRadius = UDim.new(0, 6)

local orderCounter = 0

local function createFloatingText(texto)
	orderCounter = orderCounter + 1

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0, 30)
	label.BackgroundTransparency = 1
	label.Text = texto
	label.Font = Enum.Font.SourceSansBold
	label.TextSize = 22
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 0
	label.TextXAlignment = Enum.TextXAlignment.Center
	label.RichText = false
	label.LayoutOrder = orderCounter
	label.Parent = textFrame

	task.delay(7, function()
		local steps = 30
		local interval = 0.5 / steps

		for i = 1, steps do
			if label and label.Parent then
				local t = i / steps
				label.TextTransparency = t
				label.TextStrokeTransparency = t
			end
			task.wait(interval)
		end

		if label and label.Parent then
			label:Destroy()
		end
	end)
end

textBox.FocusLost:Connect(function(enterPressed)
	if enterPressed and textBox.Text ~= "" then
		createFloatingText(textBox.Text)
		textBox.Text = ""
	end
end)

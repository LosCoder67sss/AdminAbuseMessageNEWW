-- LocalScript - Sistema de texto flotante apilado con fade out
-- Sin allowedUsers, funciona para todos

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local TweenService = game:GetService("TweenService")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TextOverlayGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local floatingMessages = {}
local MAX_MESSAGES = 67
local MESSAGE_DURATION = 7

local function calculateTextSize(messageLength)
	local baseSize = 21
	if messageLength <= 50 then return baseSize
	elseif messageLength <= 100 then return baseSize - 2
	elseif messageLength <= 150 then return baseSize - 4
	elseif messageLength <= 200 then return baseSize - 6
	elseif messageLength <= 250 then return baseSize - 8
	else return baseSize - 10 end
end

local function calculateLabelHeight(messageLength)
	if messageLength <= 80 then return 0.06
	elseif messageLength <= 160 then return 0.09
	elseif messageLength <= 240 then return 0.12
	else return 0.15 end
end

local function updatePositions()
	local currentY = 0.05
	for _, label in ipairs(floatingMessages) do
		if label.Parent then
			label.Position = UDim2.new(0.2, 0, currentY, 0)
			currentY = currentY + label.Size.Y.Scale
		end
	end
end

local function createFloatingText(message)
	if #floatingMessages >= MAX_MESSAGES then
		local oldest = table.remove(floatingMessages, 1)
		if oldest and oldest.Parent then oldest:Destroy() end
	end

	local messageLength = #message
	local labelHeight = calculateLabelHeight(messageLength)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.6, 0, labelHeight, 0)
	label.Position = UDim2.new(0.2, 0, 0.05, 0)
	label.BackgroundTransparency = 1
	label.Text = message
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeTransparency = 0.1
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextWrapped = true
	label.Font = Enum.Font.SourceSansBold
	label.TextSize = calculateTextSize(messageLength)
	label.TextXAlignment = Enum.TextXAlignment.Center
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.TextTransparency = 0
	label.Parent = screenGui

	local uiStroke = Instance.new("UIStroke")
	uiStroke.Color = Color3.fromRGB(0, 0, 0)
	uiStroke.Thickness = 0.8
	uiStroke.Transparency = 0
	uiStroke.Parent = label

	table.insert(floatingMessages, label)
	updatePositions()

	task.delay(MESSAGE_DURATION, function()
		if label and label.Parent then
			local stroke = label:FindFirstChildOfClass("UIStroke")

			local tween = TweenService:Create(label, TweenInfo.new(1.5), {
				TextTransparency = 1,
				TextStrokeTransparency = 1
			})
			tween:Play()

			if stroke then
				TweenService:Create(stroke, TweenInfo.new(1.5), {
					Transparency = 1
				}):Play()
			end

			tween.Completed:Connect(function()
				if label and label.Parent then
					label:Destroy()
					for i, v in ipairs(floatingMessages) do
						if v == label then
							table.remove(floatingMessages, i)
							break
						end
					end
					updatePositions()
				end
			end)
		end
	end)
end

-- TextBox abajo al centro
local textBox = Instance.new("TextBox")
textBox.Size = UDim2.new(0.25, 0, 0.05, 0)
textBox.Position = UDim2.new(0.375, 0, 0.85, 0)
textBox.PlaceholderText = "Escribe aquí..."
textBox.ClearTextOnFocus = false
textBox.Text = ""
textBox.TextSize = 18
textBox.TextWrapped = true
textBox.BackgroundTransparency = 1
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.Font = Enum.Font.SourceSansBold
textBox.Parent = screenGui

textBox.FocusLost:Connect(function(enterPressed)
	if enterPressed and textBox.Text ~= "" then
		local msg = tostring(textBox.Text):sub(1, 300)
		createFloatingText(msg)
		textBox.Text = ""
	end
end)
